{
  "manifest_version": 3,
  "name": "北科大 SSO+",
  "version": "26.3.13",
  "permissions": ["storage", "declarativeNetRequest"],
  "host_permissions": ["https://app.ntut.edu.tw/*"],
  "declarative_net_request": {
    "rule_resources": [{
      "id": "ruleset_1",
      "enabled": true,
      "path": "rules.json"
    }]
  },
  "action": {
    "default_popup": "popup.html"
  },
   "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "homepage_url": "https://github.com/NTUT-NPC/ntut_sso_plus",
  "description": "提供北科學生免密碼與免驗證碼快速存取校內系統的瀏覽器擴充功能。"
}